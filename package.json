{
  "name": "elma-tcg",
  "version": "1.0.0",
  "description": "This page defines rules for a possible trading card game based on Elastomania (online).",
  "engines": {
    "node": "14.x",
    "npm": "6.x"
  },
  "main": "index.js",
  "scripts": {
    "start": "run-p dev:*",
    "dev:webpack": "webpack --watch --config webpack.dev.js --mode development",
    "dev:server": "heroku local -f Procfile.dev",
    "dev:open-localhost": "open-cli http://localhost:5000/",
    "end-node": "pkill node",
    "build": "npm install --also=dev",
    "postinstall": "tsc -p tsconfig.server.json && webpack --config webpack.prod.js --mode production",
    "logs": "heroku logs --tail",
    "deploy": "git push heroku main",
    "health-check": "heroku ps:scale web=1",
    "open-app": "heroku open",
    "open-remote-dyno": "heroku run bash",
    "config-vars": "heroku config",
    "db": "heroku pg:psql"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PabloCorso/elma-tcg.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PabloCorso/elma-tcg/issues"
  },
  "homepage": "https://github.com/PabloCorso/elma-tcg#readme",
  "dependencies": {
    "@material-ui/core": "4.11.2",
    "@material-ui/icons": "4.11.2",
    "@material-ui/lab": "4.0.0-alpha.57",
    "array-move": "3.0.1",
    "express": "4.17.1",
    "pg": "8.5.1",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "react-sortable-hoc": "1.11.0"
  },
  "devDependencies": {
    "@babel/core": "7.12.10",
    "@babel/plugin-proposal-class-properties": "7.12.1",
    "@babel/plugin-proposal-object-rest-spread": "7.12.1",
    "@babel/plugin-transform-runtime": "7.12.10",
    "@babel/preset-env": "7.12.11",
    "@babel/preset-react": "7.12.10",
    "@babel/preset-typescript": "7.12.7",
    "@types/express": "4.17.11",
    "@types/node": "14.14.20",
    "@types/pg": "7.14.7",
    "@types/react-dom": "17.0.0",
    "babel-loader": "8.2.2",
    "clean-webpack-plugin": "3.0.0",
    "css-loader": "5.0.1",
    "eslint": "7.17.0",
    "eslint-plugin-react": "^7.22.0",
    "file-loader": "6.2.0",
    "foreman": "3.0.1",
    "html-webpack-plugin": "4.5.1",
    "mini-css-extract-plugin": "1.3.3",
    "nodemon": "2.0.7",
    "npm-run-all": "4.1.5",
    "open-cli": "6.0.1",
    "optimize-css-assets-webpack-plugin": "5.0.4",
    "style-loader": "2.0.0",
    "terser-webpack-plugin": "5.1.1",
    "ts-node": "9.1.1",
    "typescript": "4.1.3",
    "webpack": "5.13.0",
    "webpack-cli": "4.3.1"
  }
}
